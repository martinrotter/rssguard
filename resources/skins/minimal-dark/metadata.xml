<?xml version="1.0" encoding="UTF-8"?>
<skin version="6.6.7" base="minimal-base">
  <author>
    <name>martinrotter</name>
  </author>
  <description>Simple and good-looking dark skin.</description>

  <palette>
    <color key="FgInteresting">#f2b84b</color>
    <color key="FgSelectedInteresting">#ffd166</color>
    <color key="FgNewMessages">#69b888</color>
    <color key="FgSelectedNewMessages">#1f7a45</color>
    <color key="FgError">#ef8d82</color>
    <color key="FgSelectedError">#c94637</color>
    <color key="FgDisabledFeed">#879394</color>
    <color key="FgArticleCounts">#a1a8af</color>
    <color key="FgSelectedArticleCounts">#ffffff</color>
    <color key="Allright">#54bb7f</color>
  </palette>

  <forced-styles></forced-styles>
  
  <style-palette>
    <group id="All">
      <color role="Base">#3a3d41</color>
      <color role="AlternateBase">#2c2d30</color>
      <color role="ToolTipBase" brush="Dense1Pattern">#282a2d</color>
      <color role="Dark">#202224</color>
      <color role="Midlight">#303336</color>
      <color role="Mid">#292c2e</color>
      <color role="Shadow">#242628</color>
      <color role="Light">#5b5c61</color>

      <color role="Window">#303030</color>
      <color role="Button">#2c2d30</color>

      <color role="Text">#d9d9d9</color>
      <color role="BrightText">#f0f0f0</color>
      <color role="PlaceholderText">#a7a7a7</color>
      <color role="ToolTipText">#d8d8d8</color>
      <color role="ButtonText">#e7e7e7</color>
      <color role="WindowText">#d8d8d8</color>
      <color role="Link">#a7b7d4</color>
      <color role="LinkVisited">#b5a8c7</color>

      <color role="NoRole">#282a2d</color>
    </group>

    <group id="Disabled">
      <color role="Text">#9d9d9d</color>
      <color role="ButtonText">#aaaaaa</color>
      <color role="WindowText">#9d9d9d</color>
    </group>
  </style-palette>

</skin>